# KernelSU + SUSFS v1.5.5 config for OnePlus 8T (kebab) kernel 4.19
# Phase 1a: Add SUSFS after pure KSU verified bootable

# --- KernelSU core ---
CONFIG_KSU=y

# Manual hook is preferred over kprobes for SM8250 4.19 trees
CONFIG_KSU_MANUAL_HOOK=y
# CONFIG_KSU_KPROBES_HOOK is not set

# --- SUSFS v1.5.5 (kernel-4.19 HEAD) ---
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_KSU_DEFAULT_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_OVERLAYFS=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_TRY_UMOUNT_FOR_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_SUS_MAP=y
# CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT is not set (use AUTO_ADD instead)
CONFIG_KSU_SUSFS_ENABLE_AVC_LOG_SPOOFING=y
CONFIG_KSU_SUSFS_SUS_PATH_LOOP=y

# --- Required for Zygisk Next module compatibility ---
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

# Disable module signature checks that block module mounts
# CONFIG_MODULE_SIG_FORCE is not set
CONFIG_KERNEL_GZIP=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# KernelSU debug features (for set-manager, debug ioctls)
CONFIG_KSU_DEBUG=y

# KPM (Kernel Patch Module)
CONFIG_KPM=y
