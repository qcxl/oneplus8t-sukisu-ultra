# Boot debug: capture crash logs via pstore/ramoops
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_RAM=y
CONFIG_RAMOOPS=y

# Verbose boot logging
CONFIG_PRINTK_TIME=y
CONFIG_CONSOLE_LOGLEVEL_DEFAULT=15
CONFIG_MESSAGE_LOGLEVEL_DEFAULT=15
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DEBUG_BUGVERBOSE=y

# Early boot debug
CONFIG_EARLY_PRINTK=y

# Missing config options from stock kernel
CONFIG_COMPAT_VDSO=y
CONFIG_RELR=y
CONFIG_TOOLS_SUPPORT_RELR=y

# Use stock clang-compatible build
# CONFIG_CC_IS_CLANG is not set (keep default)

# Debug section mismatches (investigating 6 pre-existing section mismatches)
CONFIG_DEBUG_SECTION_MISMATCH=y

# Kernel cmdline for verbose boot + ramoops
# Device tree already has ramoops@b0000000, size 4MB
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="keep_bootcon initcall_debug log_buf_len=16M debug ignore_loglevel console=logk"
# Don't override bootloader cmdline, just append
CONFIG_CMDLINE_EXTEND=y
